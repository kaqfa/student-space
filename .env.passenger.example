# ============================================
# Student Space - Passenger/Domainesia Example
# Copy ke .env lalu isi nilai production:
#   cp .env.passenger.example .env
# ============================================

# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=False

# Allowed Hosts (sesuaikan dengan domain Anda)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database Configuration (PostgreSQL Domainesia)
# Format: postgresql://username:password@host:port/database_name
# Dapatkan credentials dari cPanel → PostgreSQL Databases
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Static & Media Files
# Arahkan ke direktori di bawah document root domain
# Contoh untuk exp.fahrifirdaus.my.id:
STATIC_ROOT=/home/<cpanel-user>/student-space/staticfiles
MEDIA_ROOT=/home/<cpanel-user>/student-space/media

# Security (aktifkan di production)
SECURE_SSL_REDIRECT=True

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Logging
DJANGO_LOG_LEVEL=INFO

# Application
SITE_NAME=Student Space
SITE_URL=https://yourdomain.com
