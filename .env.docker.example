# ============================================
# Student Space - Docker Environment Example
# Copy ke .env.docker lalu sesuaikan bila perlu
# ============================================

# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=docker-dev-secret-key-change-this-in-real-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,student-space-passenger

# Database Configuration (PostgreSQL via Docker service)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=studentspace
DB_USER=student
DB_PASSWORD=student123
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://student:student123@db:5432/studentspace

# Static & Media Files
STATIC_URL=/static/
STATIC_ROOT=/var/www/student-space/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/student-space/media

# Superuser (dibuat otomatis saat pertama kali start)
CREATE_SUPERUSER=true
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@localhost.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Security Settings (direlaksasi untuk lokal)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=SAMEORIGIN

# Email (console backend untuk testing)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Logging
LOG_LEVEL=INFO

# Application
SITE_NAME=Student Space
SITE_URL=http://localhost:8080

# Passenger
PASSENGER_APP_ENV=production
